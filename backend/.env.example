# API Keys (required)
TMDB_API_KEY=your_tmdb_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model (optional, default: openrouter/pony-alpha)
MODEL_NAME=openrouter/pony-alpha

# API Base URL (optional, default: https://openrouter.ai/api/v1)
API_BASE_URL=https://openrouter.ai/api/v1

# Media directory (optional, default: /media)
MEDIA_DIR=/media

# CORS origins (optional, default: http://localhost:3000)
ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000
