# NAS Deployment Configuration Example
# Copy this file to .env and adjust the values for your NAS environment

# Directory where your movies are stored on the NAS
MEDIA_DIR=/volume1/video/movies

# Your API Keys
TMDB_API_KEY=your_tmdb_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Note: Front-end now automatically connects to the backend internally.
# You do not need to configure NAS IP for frontend API requests.
